---
// Enterprise stat band — animated counters on a deep nanquim ground, right under
// the hero. The numbers count up when scrolled into view (CountUp island).
import CountUp from "../islands/CountUp.tsx";
import { useTranslations, toLang } from "../../i18n/ui";

const t = useTranslations(toLang(Astro.currentLocale)).stats;
const nums = [
  { to: 5, suffix: "" },
  { to: 3, suffix: "" },
  { to: 31, suffix: "" },
  { to: 2, suffix: "" },
];
const stats = nums.map((n, i) => ({ ...n, label: t.labels[i] }));
---

<section class="statband surface-ink-deep on-ink" aria-label={t.ariaLabel}>
  <div class="wrap statband-inner">
    {
      stats.map((s, i) => (
        <div class="stat reveal" style={`transition-delay:${i * 90}ms`}>
          <CountUp client:visible to={s.to} suffix={s.suffix} />
          <p class="stat-label">{s.label}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .statband { padding-block: 64px; position: relative; }
  .statband-inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 24px;
  }
  @media (min-width: 880px) {
    .statband-inner { grid-template-columns: repeat(4, 1fr); }
  }
  .stat { position: relative; }
  .stat::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    width: 26px;
    height: 3px;
    background: var(--urucum);
    border-radius: 2px;
  }
  .stat-label {
    margin: 14px 0 0;
    font-size: 14px;
    line-height: 1.4;
    color: var(--inv-soft);
    max-width: 22ch;
  }
</style>
