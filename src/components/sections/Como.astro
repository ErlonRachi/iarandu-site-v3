---
import { useTranslations, toLang } from "../../i18n/ui";

const t = useTranslations(toLang(Astro.currentLocale)).como;
const steps = t.steps.map((s, i) => ({
  n: String(i + 1).padStart(2, "0"),
  ...s,
}));
---

<section id="como" class="surface-ink on-ink sec como">
  <div class="wrap como-inner">
    <header class="como-head">
      <div class="badge reveal">
        <span class="badge-dot" aria-hidden="true"></span>
        {t.badge}
      </div>
      <h2 class="h2 como-h" data-words>{t.h}</h2>
      <p class="body-lg measure como-intro reveal" style="transition-delay:120ms;">
        {t.intro}
      </p>
    </header>

    <div class="como-steps">
      <!-- flowing connector line behind the steps -->
      <svg class="river como-river" viewBox="0 0 1200 40" preserveAspectRatio="none" aria-hidden="true">
        <path d="M40 20 H1160" />
        <path class="flow" d="M40 20 H1160" />
      </svg>

      {steps.map((s, i) => (
        <article class="como-step reveal" style={`transition-delay:${i * 140}ms;`}>
          <span class="como-num">{s.n}</span>
          <h3 class="h3 como-step-title">{s.title}</h3>
          <p class="body como-step-body">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .como { position: relative; overflow: hidden; isolation: isolate; }
  .como-inner { position: relative; z-index: 1; }

  .como-head { max-width: 60ch; }
  .como-h { margin: 18px 0 0; max-width: 26ch; }
  .como-intro { margin: 24px 0 0; }

  .como-steps {
    position: relative;
    margin-top: clamp(48px, 6vw, 80px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 768px) {
    .como-steps { grid-template-columns: repeat(3, 1fr); gap: 40px; }
  }

  .como-river {
    display: none;
    position: absolute;
    top: 38px;
    left: 0;
    right: 0;
    height: 40px;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .como-river { display: block; }
  }

  .como-step { position: relative; z-index: 1; }
  .como-num {
    display: block;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 700;
    font-variation-settings: "opsz" 144, "SOFT" 40;
    font-size: clamp(56px, 6vw, 92px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--urucum);
  }
  .como-step-title { margin: 18px 0 0; }
  .como-step-body { margin: 12px 0 0; }
</style>
