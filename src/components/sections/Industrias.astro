---
// Industrias — regulated-industries proof of capability.
// Surface: cream. Four cards (sector chip · industry name · body), last is the
// "your industry" invitation. Brand is always "iarandu". Never name the client.
import { useTranslations, toLang } from "../../i18n/ui";

const t = useTranslations(toLang(Astro.currentLocale)).industrias;
---

<section id="industrias" class="industrias surface-cream sec">
  <div class="wrap">
    <header class="ind-head">
      <div class="badge reveal">
        <span class="badge-dot" aria-hidden="true"></span>
        {t.badge}
      </div>
      <h2 class="h2 ind-h" data-words>{t.h}</h2>
      <p class="body-lg measure ind-intro reveal" style="transition-delay:120ms;">
        {t.intro}
      </p>
    </header>

    <div class="ind-grid">
      {t.cards.map((c, i) => (
        <article class="card ind-card reveal" style={`transition-delay:${80 + i * 100}ms;`}>
          <span class="chip">{c.chip}</span>
          <h3 class="h3 ind-name">{c.name}</h3>
          <p class="body">{c.body}</p>
        </article>
      ))}

      <article class="card ind-card ind-card-invite reveal" style="transition-delay:380ms;">
        <span class="seed float-slow ind-card-seed" aria-hidden="true"></span>
        <span class="chip">{t.invite.chip}</span>
        <h3 class="h3 ind-name">{t.invite.name}</h3>
        <p class="body">{t.invite.body}</p>
        <a href="#vamos" class="btn-ghost ind-invite-cta">
          {t.invite.cta}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </article>
    </div>
  </div>
</section>

<style>
  .ind-head { max-width: 56rem; }
  .ind-h { margin: 18px 0 0; }
  .ind-intro { margin: 22px 0 0; }

  .ind-grid {
    margin-top: clamp(40px, 5vw, 64px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 720px) {
    .ind-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .ind-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }
  .ind-name { margin: 0; }
  .ind-card .body { margin: 0; }

  /* Invitation card — warmer ground, urucum accent (one per section) */
  .ind-card-invite {
    background:
      radial-gradient(140% 120% at 100% 0%, color-mix(in oklab, var(--urucum-soft) 26%, transparent), transparent 58%),
      var(--papel-soft);
    border-color: var(--line-strong);
  }
  .ind-card-invite .chip {
    border-color: color-mix(in oklab, var(--urucum) 40%, transparent);
    color: var(--urucum);
  }
  .ind-card-seed {
    position: absolute;
    width: 120px;
    height: 120px;
    right: -28px;
    bottom: -28px;
    opacity: 0.16;
    filter: blur(2px);
    pointer-events: none;
  }
  .ind-invite-cta { margin-top: 6px; }
  .ind-invite-cta .arrow { transition: transform 240ms var(--ease-spring); }
  .ind-invite-cta:hover .arrow { transform: translateX(5px); }
</style>
