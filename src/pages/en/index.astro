---
// /en — iarandu, UK English. Same composition as the pt root; sections read
// their copy from the i18n dictionary via Astro.currentLocale ("en").
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/sections/Hero.astro";
import StatBand from "../../components/sections/StatBand.astro";
import Plataforma from "../../components/sections/Plataforma.astro";
import Como from "../../components/sections/Como.astro";
import Industrias from "../../components/sections/Industrias.astro";
import Provas from "../../components/sections/Provas.astro";
import Governanca from "../../components/sections/Governanca.astro";
import Socios from "../../components/sections/Socios.astro";
import Fechamento from "../../components/sections/Fechamento.astro";
import Footer from "../../components/sections/Footer.astro";
---

<Layout>
  <main>
    <Hero />
    <StatBand />
    <Plataforma />
    <Como />
    <Industrias />
    <Provas />
    <Governanca />
    <Socios />
    <Fechamento />
  </main>
  <Footer />
</Layout>
